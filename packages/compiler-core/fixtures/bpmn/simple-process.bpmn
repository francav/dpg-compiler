<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
    targetNamespace="https://example.com/bpmn">
    <process id="Process_Simple" name="Simple Process">
        <startEvent id="StartEvent_1" name="start">
            <outgoing>SequenceFlow_1</outgoing>
        </startEvent>
        <serviceTask id="ServiceTask_1" name="Invoke Service">
            <incoming>SequenceFlow_1</incoming>
            <outgoing>SequenceFlow_2</outgoing>
        </serviceTask>
        <endEvent id="EndEvent_1" name="end">
            <incoming>SequenceFlow_2</incoming>
        </endEvent>
        <sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="ServiceTask_1" />
        <sequenceFlow id="SequenceFlow_2" sourceRef="ServiceTask_1" targetRef="EndEvent_1" />
    </process>
</definitions>
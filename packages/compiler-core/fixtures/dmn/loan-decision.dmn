<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" id="Definitions_1" name="Loan Decision" namespace="https://example.com/dmn">
  <decision id="Decision_LoanApproval" name="Loan Approval">
    <informationRequirement>
      <requiredDecision href="#Decision_RiskCategory" />
    </informationRequirement>
    <decisionTable id="DecisionTable_Approval" hitPolicy="FIRST">
      <input id="Input_Risk" label="Risk">
        <inputExpression id="InputExpression_Risk" typeRef="string">
          <text>riskCategory</text>
        </inputExpression>
      </input>
      <output id="Output_Approval" label="Approval" typeRef="string" />
      <rule id="Rule_1">
        <inputEntry id="InputEntry_1">
          <text>"LOW"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_1">
          <text>"APPROVE"</text>
        </outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="InputEntry_2">
          <text>"MEDIUM"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_2">
          <text>"REVIEW"</text>
        </outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="InputEntry_3">
          <text>"HIGH"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_3">
          <text>"REJECT"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="Decision_RiskCategory" name="Risk Category">
    <decisionTable id="DecisionTable_Risk" hitPolicy="FIRST">
      <input id="Input_Score" label="Score">
        <inputExpression id="InputExpression_Score" typeRef="number">
          <text>creditScore</text>
        </inputExpression>
      </input>
      <output id="Output_Risk" label="Risk" typeRef="string" />
      <rule id="Rule_Risk_1">
        <inputEntry id="InputEntry_Risk_1">
          <text>&gt; 750</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Risk_1">
          <text>"LOW"</text>
        </outputEntry>
      </rule>
      <rule id="Rule_Risk_2">
        <inputEntry id="InputEntry_Risk_2">
          <text>&gt; 600</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Risk_2">
          <text>"MEDIUM"</text>
        </outputEntry>
      </rule>
      <rule id="Rule_Risk_3">
        <inputEntry id="InputEntry_Risk_3">
          <text>&lt;= 600</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Risk_3">
          <text>"HIGH"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
